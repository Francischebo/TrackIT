FLASK_ENV=production
FLASK_APP=run.py
# Generate strong keys: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# DATABASE_URL=sqlite:///trackit.db
# For PostgreSQL/Supabase, ensure sslmode=require
DATABASE_URL_PROD=postgresql://user:password@localhost:5432/trackit?sslmode=require

DEBUG=False
FORCE_HTTPS=True
CORS_ORIGINS=https://your-frontend-domain.com
BCRYPT_LOG_ROUNDS=12

# Cron keepalive (cron-job.org every 10 min): /cron/keepalive?token=YOUR_SECRET
# CRON_SECRET=generate-with-python-secrets-token_hex-16
